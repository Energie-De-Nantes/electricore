    {
      "type": "text", "id": "orch_term_t", "x": 55, "y": 1132, "width": 610, "height": 90,
      "text": "$ ingestion.py test       # smoke — 2 fichiers par flux\n$ ingestion.py all        # landing + dbt build\n$ ingestion.py r151 c15   # sélection de flux\n$ ingestion.py rebuild    # dbt seul — zéro réseau, ~13 s\n$ ingestion.py resync     # re-télécharge tout (brut perdu)",
      "originalText": "$ ingestion.py test       # smoke — 2 fichiers par flux\n$ ingestion.py all        # landing + dbt build\n$ ingestion.py r151 c15   # sélection de flux\n$ ingestion.py rebuild    # dbt seul — zéro réseau, ~13 s\n$ ingestion.py resync     # re-télécharge tout (brut perdu)",
      "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#e2e8f0", "backgroundColor": "transparent", "fillStyle": "solid",
