      "type": "text", "id": "ev_sql_t", "x": 1585, "y": 262, "width": 340, "height": 212,
      "text": "-- flux_c15.sql (extrait réel)\nselect\n  prm ->> '$.Id_PRM'  as pdl,\n  cast(prm ->> '$…Puissance_Souscrite'\n       as double) as puissance_souscrite_kva,\n  …\nwhere code_qualif in ('1', '2')\n  and classe_mesure = '1'   -- index\n  and sens_mesure   = '0'   -- soutirage",
      "originalText": "-- flux_c15.sql (extrait réel)\nselect\n  prm ->> '$.Id_PRM'  as pdl,\n  cast(prm ->> '$…Puissance_Souscrite'\n       as double) as puissance_souscrite_kva,\n  …\nwhere code_qualif in ('1', '2')\n  and classe_mesure = '1'   -- index\n  and sens_mesure   = '0'   -- soutirage",
      "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
