# Secrets pour le pipeline ETL Enedis
# Copiez ce fichier vers secrets.toml et remplissez vos valeurs
# ⚠️ Ne jamais committer secrets.toml (déjà dans .gitignore)

# ===========================================
# CONNEXION SFTP ENEDIS
# ===========================================

[sftp]
# URL SFTP complète avec authentification
# Format: sftp://username:password@hostname[:port]/path
url = "sftp://votre_identifiant:votre_mot_de_passe@sftp.enedis.fr:22/flux_enedis"

# ===========================================
# CLÉS DE DÉCHIFFREMENT AES ENEDIS
# ===========================================

# Format simple (une seule clé active)
[aes]
# Clé AES-128 (16 bytes = 32 caractères hex)
key = "00000000000000000000000000000000"
# Vecteur d'initialisation (16 bytes = 32 caractères hex)
iv  = "00000000000000000000000000000000"

# --- OU --- Format avec rotation de clés (recommandé lors d'une rotation Enedis) ---
# Décommentez et utilisez ce format lors d'un changement de clé Enedis.
# Voir CLAUDE.md section "Rotation des clés AES" pour la procédure.
#
# [aes.current]
# key = "nouvelle_clé_hex"
# iv  = "nouvel_iv_hex"
#
# [aes.previous]   # Garder ~4 semaines après rotation, puis supprimer
# key = "ancienne_clé_hex"
# iv  = "ancien_iv_hex"

# ===========================================
# INSTANCE ODOO (optionnel)
# ===========================================

# [odoo_test]
# # Instance Odoo de test — utilisée par tests/integration/test_odoo_writer.py
# # Si cette section est absente, les tests d'intégration Odoo sont skippés.
# url = "https://votre-instance-test.odoo.com"
# db = "nom-de-la-base"
# username = "votre@email.com"
# password = "votre_mot_de_passe"

