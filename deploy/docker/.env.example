# ===========================================
# .env de PRODUCTION pour la stack docker-compose ElectriCore
# ===========================================
# À placer à la racine du dossier de déploiement (cf. docs/deploiement.md) :
#   /opt/electricore/.env          ← ici
#   /opt/electricore/deploy/docker/docker-compose.yml
#
# Le compose le lit via `env_file: ../../.env`.
# Ne jamais committer ce fichier rempli.

# -------------------------------------------
# Version d'image
# -------------------------------------------
# Tag de l'image GHCR à déployer (latest, 1.4.0, 1.4, ...)
ELECTRICORE_VERSION=latest

# -------------------------------------------
# Clé API (requise par le scheduler ETL pour appeler /etl/run)
# -------------------------------------------
# Générer une clé sécurisée :
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Doit être DÉFINIE (le cron utilise $API_KEY pour curl /etl/run).
API_KEY=remplacez-cette-cle-par-une-cle-aleatoire-32-octets

# Clés additionnelles autorisées (séparées par des virgules, optionnel)
# API_KEYS=key1,key2,key3

# -------------------------------------------
# Bot Telegram (optionnel)
# -------------------------------------------
# Laisser vide si vous n'utilisez pas le bot. Token via @BotFather.
TELEGRAM_BOT_TOKEN=
# IDs Telegram autorisés (séparés par des virgules) — @userinfobot pour le trouver
TELEGRAM_ALLOWED_USERS=

# URL que le bot utilise pour joindre l'API (réseau interne docker-compose)
API_BASE_URL=http://api:8001

# -------------------------------------------
# Source des flux Enedis (deux modes)
# -------------------------------------------

# Mode A — SFTP distant (par défaut, fichiers téléchargés depuis Enedis) :
SFTP__URL=sftp://utilisateur:motdepasse@hote.enedis.fr:22/exports

# Mode B — Fichiers collocés sur le VPS (pas de re-téléchargement) :
#   1. Décommenter la ligne ci-dessous
#   2. Décommenter le bind-mount /var/enedis dans docker-compose.yml
#   3. Les fichiers restent chiffrés AES — les clés AES__* sont obligatoires
# SFTP__URL=file:///var/enedis/

# -------------------------------------------
# Clés AES Enedis (toujours requises, même en mode collocé)
# -------------------------------------------
# Format v1 (clé unique) :
AES__KEY=hex_key_32_caracteres
AES__IV=hex_iv_32_caracteres

# Format v2 (rotation, recommandé pour la prod) :
# AES__CURRENT__KEY=nouvelle_cle_hex
# AES__CURRENT__IV=nouvel_iv_hex
# AES__PREVIOUS__KEY=ancienne_cle_hex   # ~4 semaines après rotation
# AES__PREVIOUS__IV=ancien_iv_hex

# -------------------------------------------
# Odoo (optionnel — requis pour les endpoints /taxes/* et /facturation/check/odoo)
# -------------------------------------------
# ODOO_ENV=prod
# ODOO_PROD_URL=https://odoo.exemple.fr
# ODOO_PROD_DB=nom_base
# ODOO_PROD_USERNAME=utilisateur@example.com
# ODOO_PROD_PASSWORD=mot_de_passe
