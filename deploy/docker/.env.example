# ===========================================
# .env de PRODUCTION pour la stack docker-compose ElectriCore
# ===========================================
# Layout attendu (cf. ADR-0017 + docs/deploiement.md) :
#   /srv/<slug>/.env                       ← ce fichier
#   /srv/<slug>/deploy/docker/docker-compose.yml
#
# Le compose le lit via `env_file: ../../.env`.
# Ne JAMAIS committer ce fichier rempli.
#
# Les lignes `# TODO: à remplir` marquent les valeurs obligatoires. Le script
# d'installation (deploy/install.sh) ouvre ce fichier dans $EDITOR et valide
# chaque champ après la fermeture de l'éditeur. Les commentaires « Format: »
# décrivent la règle de validation appliquée.

# -------------------------------------------
# Identité de l'instance (ADR-0015)
# -------------------------------------------
# Slug court de l'instance — apparaît dans /health, dans le titre OpenAPI,
# dans le préfixe des backups, et matche le user système /srv/<slug>/.
# Doit matcher la valeur passée à install.sh --slug.
# Format: [a-z0-9-]+ (minuscules, chiffres, tirets ; pas d'underscore)
INSTANCE_SLUG=  # TODO: à remplir

# Tag de l'image GHCR à déployer (latest, 1.7.0, 1.7, ...)
# Pin explicite recommandé en prod pour rollback contrôlé.
ELECTRICORE_VERSION=latest

# -------------------------------------------
# Layout déploiement (ADR-0017)
# -------------------------------------------
# Chemin host où les backups DuckDB sont bind-mountés. Sur un VPS provisionné
# par install.sh : /srv/<slug>/backups (le script substitue automatiquement).
# Sur dev local depuis le repo : laisser la valeur ./backups, ou l'omettre
# pour laisser le défaut du compose ($BACKUPS_PATH:-./backups).
# Format: chemin absolu (prod) ou relatif au cwd de `docker compose` (dev)
BACKUPS_PATH=/srv/electricore/backups  # TODO: remplacer `electricore` par le slug réel

# -------------------------------------------
# API — Authentification
# -------------------------------------------
# Clé API principale (utilisée par le scheduler ETL pour appeler /etl/run).
# Générer une clé sécurisée :
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Format: chaîne non-vide, ≥ 32 caractères
API_KEY=  # TODO: à remplir

# Clés additionnelles autorisées (séparées par des virgules, optionnel).
# Utile pour les notebooks distants, les intégrations tierces.
# API_KEYS=key1,key2,key3

# -------------------------------------------
# Source des flux Enedis (deux modes)
# -------------------------------------------
# Mode A — SFTP distant (par défaut, fichiers téléchargés depuis Enedis).
# Mode B — Fichiers collocés sur le VPS : `file:///var/enedis/`
#   (+ décommenter le bind-mount /var/enedis dans docker-compose.yml service api)
#
# Format: sftp://user:pass@host:port/path  OU  file:///chemin/local/
SFTP__URL=  # TODO: à remplir

# -------------------------------------------
# Clés AES Enedis (toujours requises, même en mode collocé)
# -------------------------------------------
# Format recommandé v2 (supporte la rotation, cf. docs/deploiement.md).
# Format: hexadécimal, 32 ou 64 caractères (selon la cuvée Enedis)
AES__CURRENT__KEY=  # TODO: à remplir
AES__CURRENT__IV=   # TODO: à remplir

# Clés précédentes — à activer ~4 semaines après une rotation pour permettre
# le déchiffrement des anciens fichiers encore présents sur le SFTP.
# AES__PREVIOUS__KEY=ancienne_cle_hex
# AES__PREVIOUS__IV=ancien_iv_hex

# Format v1 (legacy, clé unique sans rotation) — encore supporté :
# AES__KEY=hex_key
# AES__IV=hex_iv

# -------------------------------------------
# Bot Telegram (optionnel)
# -------------------------------------------
# Laisser vide si vous n'utilisez pas le bot. Token via @BotFather.
# Convention de nommage : <slug>_electricore_bot
TELEGRAM_BOT_TOKEN=

# IDs Telegram autorisés (séparés par des virgules) — @userinfobot pour les
# trouver. L'allowlist est obligatoire si TELEGRAM_BOT_TOKEN est défini.
TELEGRAM_ALLOWED_USERS=

# URL que le bot utilise pour joindre l'API (réseau interne docker-compose).
# Ne pas modifier en déploiement standard.
API_BASE_URL=http://api:8001

# -------------------------------------------
# Odoo (optionnel — requis pour /taxes/* et /facturation/check/odoo)
# -------------------------------------------
# Laisser commenté si pas d'Odoo. Sinon, dé-commenter et remplir.
# ODOO_ENV=prod
# ODOO_PROD_URL=https://odoo.exemple.fr
# ODOO_PROD_DB=nom_base
# ODOO_PROD_USERNAME=utilisateur@example.com
# ODOO_PROD_PASSWORD=mot_de_passe
