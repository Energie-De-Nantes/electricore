# Configuration de l'API ElectriCore
# Copiez ce fichier vers .env et adaptez les valeurs selon votre environnement

# ===========================================
# CONFIGURATION DES CLÉS API
# ===========================================

# Méthode 1: Une seule clé API principale
API_KEY=your-secure-api-key-here

# Méthode 2: Plusieurs clés API (séparées par des virgules)
# API_KEYS=key1,key2,key3

# ===========================================
# CONFIGURATION DE L'API
# ===========================================

# Métadonnées de l'API
API_TITLE="ElectriCore API"
API_VERSION="0.1.0"
API_DESCRIPTION="API sécurisée pour accéder aux données flux Enedis"

# Méthode d'authentification (header X-API-Key uniquement)
ENABLE_API_KEY_HEADER=true

# Endpoints publics (JSON array format)
# PUBLIC_ENDPOINTS='["/", "/health", "/docs", "/redoc", "/openapi.json"]'

# ===========================================
# EXEMPLES DE CLÉS API SÉCURISÉES
# ===========================================

# Pour générer une clé API sécurisée, utilisez :
# python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# Ou avec OpenSSL :
# openssl rand -base64 32
#
# Exemples de clés générées :
# API_KEY=Kx9vR4mN3pQ7wL2sF8uE6tY1nC5hB0jD9rI4oP7xZ2aV3wQ8mK1sL6fE
# API_KEYS=abc123def456,xyz789uvw012,mno345pqr678

# ===========================================
# SÉCURITÉ
# ===========================================

# IMPORTANT :
# - Ne jamais committer le fichier .env dans le contrôle de version
# - Utiliser des clés longues et aléatoires (32+ caractères)
# - Changer les clés régulièrement
# - Limiter l'accès aux clés aux personnes autorisées
# - Utiliser HTTPS en production

# ===========================================
# BOT TELEGRAM (optionnel)
# ===========================================

# Token du bot obtenu via @BotFather sur Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# IDs Telegram autorisés à utiliser le bot (séparés par des virgules)
# Pour trouver votre ID : envoyez un message à @userinfobot
TELEGRAM_ALLOWED_USERS=123456789,987654321

# ===========================================
# BASE DE DONNÉES
# ===========================================

# Chemin vers la base DuckDB (partagée par l'ETL et l'API)
# Par défaut : electricore/etl/flux_enedis_pipeline.duckdb (relatif au répertoire de travail)
# En production, utilisez un chemin absolu :
# DUCKDB_PATH=/opt/electricore/data/flux_enedis_pipeline.duckdb

# ===========================================
# ODOO (connexion pour calculs CTA/Accise)
# ===========================================

# Instance active : "test" ou "prod"
ODOO_ENV=test

# Odoo TEST
ODOO_TEST_URL=https://test.odoo.com
ODOO_TEST_DB=nom_base_test
ODOO_TEST_USERNAME=utilisateur@example.com
ODOO_TEST_PASSWORD=mot_de_passe_test

# Odoo PROD
ODOO_PROD_URL=https://prod.odoo.com
ODOO_PROD_DB=nom_base_prod
ODOO_PROD_USERNAME=utilisateur@example.com
ODOO_PROD_PASSWORD=mot_de_passe_prod

# ===========================================
# ETL ENEDIS (DLT — format SECTION__CLÉ)
# ===========================================
# DLT résout automatiquement ces variables pour dlt.secrets['sftp']['url'] etc.

# Connexion SFTP Enedis
SFTP__URL=sftp://utilisateur:motdepasse@hote:22/chemin

# Clés AES Enedis — format simple (v1)
AES__KEY=hex_key_32_caracteres
AES__IV=hex_iv_32_caracteres

# Ou format rotation v2 (recommandé) :
# AES__CURRENT__KEY=nouvelle_cle_hex
# AES__CURRENT__IV=nouvel_iv_hex
# AES__PREVIOUS__KEY=ancienne_cle_hex   # optionnel, ~4 semaines après rotation
# AES__PREVIOUS__IV=ancien_iv_hex